{
  "name": "@kako351/react-native-game-radar",
  "version": "0.1.1",
  "description": "A game-style radar chart component for React Native. Built for dark UI, RPG stats, and modern game interfaces.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "source": "src/index",
  "exports": {
    ".": {
      "types": "./lib/typescript/index.d.ts",
      "default": "./lib/commonjs/index.js"
    }
  },
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "bob build",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "radar",
    "chart",
    "game",
    "ui",
    "svg",
    "rpg",
    "stats"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kako351/react-native-game-radar.git"
  },
  "author": "kako351",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kako351/react-native-game-radar/issues"
  },
  "homepage": "https://github.com/kako351/react-native-game-radar#readme",
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72",
    "react-native-svg": ">=13"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-builder-bob": "^0.33.0",
    "react-native-svg": "^15.9.0",
    "typescript": "^5.3.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}
